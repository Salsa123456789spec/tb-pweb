<script>
    // Dropdown functionality for data per page
    const dataPerPageBtn = document.getElementById('dataPerPageBtn');
    const dataPerPageSelect = document.getElementById('dataPerPageSelect');
    const dataPerPageValue = document.getElementById('dataPerPageValue');

    dataPerPageBtn.addEventListener('click', () => {
        if (dataPerPageSelect.classList.contains('hidden')) {
            dataPerPageSelect.classList.remove('hidden');
            dataPerPageSelect.focus();
        } else {
            dataPerPageSelect.classList.add('hidden');
        }
    });

    dataPerPageSelect.addEventListener('change', () => {
        dataPerPageValue.textContent = dataPerPageSelect.value;
        dataPerPageSelect.classList.add('hidden');
        // Here you can add logic to update the table data based on selected value
        console.log('Data per page changed to:', dataPerPageSelect.value);
    });

    dataPerPageSelect.addEventListener('blur', () => {
        setTimeout(() => {
            dataPerPageSelect.classList.add('hidden');
        }, 150);
    });

    // Close dropdown when clicking outside
    document.addEventListener('click', (event) => {
        if (!dataPerPageBtn.contains(event.target) && !dataPerPageSelect.contains(event.target)) {
            dataPerPageSelect.classList.add('hidden');
        }
    });
</script> 